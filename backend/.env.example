# UNMAPPED backend configuration
# Copy this file to .env and adjust as needed.

# Logging level (DEBUG, INFO, WARNING, ERROR)
UNMAPPED_LOG_LEVEL=INFO

# Cache TTL for crawled data (hours)
UNMAPPED_CACHE_TTL_HOURS=24

# Optional: enable semantic embeddings fallback (requires sentence-transformers, ~90MB model)
UNMAPPED_ENABLE_EMBEDDINGS=false

# Optional: allow live ESCO API calls during request (for unknown skills)
UNMAPPED_ENABLE_ESCO_FALLBACK=true

# Network timeouts
UNMAPPED_HTTP_TIMEOUT_SECONDS=20
UNMAPPED_HTTP_MAX_RETRIES=3

# Default fuzzy match threshold (0-100)
UNMAPPED_FUZZY_THRESHOLD=80

# Tavily integration (live opportunity feed + policymaker news strip)
# Get a key at https://app.tavily.com/. Without a key, the system falls back to
# the offline static training hints — the demo still works, just no live results.
UNMAPPED_ENABLE_TAVILY=true
UNMAPPED_TAVILY_API_KEY=
UNMAPPED_TAVILY_MAX_RESULTS=5
UNMAPPED_TAVILY_NEWS_DAYS=180

# Data directory (override only if running outside the repo)
# UNMAPPED_DATA_DIR=./data
