# Copy this file to `.env.local` and fill in real values for local development.
# Vite only exposes variables prefixed with `VITE_` to client code.
# In production set the same vars in the Vercel dashboard
# (Project Settings → Environment Variables).

# Base URL of the UNMAPPED backend API. Leave blank to use the in-browser
# mock dataset bundled with the app.
VITE_API_URL=

# Tavily API key used by future live-search features.
VITE_TAVILY_API_KEY=
