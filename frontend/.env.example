# Copy this file to `.env` (or `.env.local`) and fill in the values.
# All variables exposed to the browser must be prefixed with VITE_.

# Base URL of the backend API. Leave empty to use mock data.
VITE_API_URL=

# Tavily web-search API key. Forwarded to the backend via the
# X-Tavily-Api-Key header when set.
VITE_TAVILY_API_KEY=

# Optional: serve the app under a sub-path. Defaults to "/".
# VITE_BASE_URL=/
