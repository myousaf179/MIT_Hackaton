# Frontend environment variables (Vite)
# Copy to `.env.local` and fill in real values for local development.
# Only variables prefixed with VITE_ are exposed to the client bundle.

# Base URL of the UNMAPPED backend API.
# Leave empty in development to use the built-in mock data in `src/api.ts`.
# Example: https://api.unmapped.example.com
VITE_API_BASE=
