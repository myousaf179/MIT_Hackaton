# Vite: copy to .env.local and adjust.
# VITE_API_URL must match your FastAPI host (no trailing slash).

VITE_API_URL=http://127.0.0.1:8000

# Optional: client-side Tavily (verifier / experiments). The backend can also
# use UNMAPPED_TAVILY_API_KEY in backend/.env for server-side search.
VITE_TAVILY_API_KEY=
